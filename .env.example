# ─────────────────────────────────────────────────────────────
#  RAG Customer Support Assistant — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── OpenAI (required) ────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── LangSmith Tracing (optional but recommended) ─────────────
# Get your key at: https://smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls__your-langsmith-api-key-here
LANGSMITH_PROJECT=rag-customer-support
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── FastAPI server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit (override where the UI finds the API) ───────────
API_BASE_URL=http://localhost:8000
